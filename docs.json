{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "WAT Rooms",
  "description": "Book WAT meeting rooms from the web app, the wat CLI, or your AI coding agent.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Open the app",
          "icon": "calendar-check",
          "href": "https://wat-app.vercel.app"
        }
      ]
    },
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "index",
          "quickstart",
          "account"
        ]
      },
      {
        "group": "Tools",
        "icon": "terminal",
        "expanded": true,
        "pages": [
          "cli",
          "plugin"
        ]
      },
      {
        "group": "Reference",
        "icon": "book-open",
        "expanded": true,
        "pages": [
          "booking-rules"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open the app",
      "href": "https://wat-app.vercel.app"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/WATbeta"
    }
  }
}
